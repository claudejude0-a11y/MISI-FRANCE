# --- MISI France — config Apache pour hébergement mutualisé OVH ---
# Placé dans public/ : Next.js le recopie automatiquement dans out/ à chaque build.

Options -MultiViews
RewriteEngine On

# 1) Forcer HTTPS (OVH mutualisé est derrière un proxy → tester X-Forwarded-Proto)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2) Forcer le www (le site est canonique sur www.misifrance.com)
RewriteCond %{HTTP_HOST} ^misifrance\.com$ [NC]
RewriteRule ^ https://www.misifrance.com%{REQUEST_URI} [R=301,L]

# 3) URLs propres : servir /contact depuis /contact.html (export statique Next.js)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 4) Page 404 personnalisée
ErrorDocument 404 /404.html

# 5) Cache long pour les assets versionnés (_next/static est immuable)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
